# Required. Keep real values in .env, never in git.
eufy_email=
eufy_pass=

# Optional. Defaults are US and en.
EUFY_COUNTRY=US
EUFY_LANGUAGE=en

# Optional live verification target. Keep real property aliases/serials in your
# ignored config/properties.local.yaml; do not commit production values.
EUFY_LIVE_TEST_PROPERTY=sample-property
EUFY_LIVE_TEST_LOCK_ALIAS=front
EUFY_LIVE_TEST_LOCK_SERIAL=
EUFY_CONFIRM_LIVE_WRITE=0
